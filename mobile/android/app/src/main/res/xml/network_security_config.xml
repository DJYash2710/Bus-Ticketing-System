<?xml version="1.0" encoding="utf-8"?>
<!-- Dev API uses HTTP on the LAN (e.g. http://192.168.x.x:4000). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
  OPERATOR
}

enum BusType {
  SEATER
  SLEEPER
  SEMI_SLEEPER
  AC
  NON_AC
}

enum ScheduleStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  REFUND_PENDING
  CANCELLED
}

enum CouponType {
  PERCENT
  FIXED
}

enum LoyaltyEventType {
  EARN_BOOKING
  EARN_REFERRAL
  REDEEM_BOOKING
  ADJUSTMENT
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)

  referralCode String? @unique
  referredById Int?
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("UserReferrals")

  creditsBalance Int @default(0)

  busOperatorId Int?
  managedOperator BusOperator? @relation(fields: [busOperatorId], references: [id])

  bookings          Booking[]
  refreshTokens     RefreshToken[]
  loyaltyEvents     LoyaltyEvent[]
  couponRedemptions CouponRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  userAgent String?
  ipAddress String?
  isRevoked Boolean  @default(false)
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRevoked])
  @@index([expiresAt])
}

// ─── Operator ────────────────────────────────────────────────────────────────

model BusOperator {
  id           Int     @id @default(autoincrement())
  name         String
  contactEmail String?
  contactPhone String?

  buses Bus[]
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Cities & Routes ─────────────────────────────────────────────────────────

model City {
  id      Int     @id @default(autoincrement())
  name    String
  state   String?
  country String? @default("India")

  busStops   BusStop[]
  routesFrom Route[] @relation("RouteFromCity")
  routesTo   Route[] @relation("RouteToCity")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, state, country])
}

model BusStop {
  id       Int    @id @default(autoincrement())
  name     String
  locality String
  cityId   Int

  city          City    @relation(fields: [cityId], references: [id])
  routesAsStart Route[] @relation("RouteStartStop")
  routesAsEnd   Route[] @relation("RouteEndStop")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cityId])
}

model Route {
  id                       Int    @id @default(autoincrement())
  code                     String @unique
  fromCityId               Int
  toCityId                 Int
  startBusStopId           Int?
  endBusStopId             Int?
  distanceKm               Int?
  durationMin              Int?
  estimatedDurationMinutes Int?

  fromCity     City     @relation("RouteFromCity", fields: [fromCityId], references: [id])
  toCity       City     @relation("RouteToCity", fields: [toCityId], references: [id])
  startBusStop BusStop? @relation("RouteStartStop", fields: [startBusStopId], references: [id])
  endBusStop   BusStop? @relation("RouteEndStop", fields: [endBusStopId], references: [id])
  schedules    Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fromCityId, toCityId])
}

// ─── Bus ─────────────────────────────────────────────────────────────────────

model Bus {
  id             Int     @id @default(autoincrement())
  operatorId     Int?
  registrationNo String  @unique
  name           String
  capacity       Int
  type           BusType
  amenities      String?

  operator  BusOperator? @relation(fields: [operatorId], references: [id])
  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Schedule ────────────────────────────────────────────────────────────────

model Schedule {
  id                     Int            @id @default(autoincrement())
  routeId                Int
  busId                  Int
  departureTime          DateTime
  arrivalTime            DateTime?
  basePrice              Decimal        @db.Decimal(10, 2)
  status                 ScheduleStatus @default(ACTIVE)
  color                  String?        @default("#4F46E5")
  recurrenceGroupId      String?
  isRecurrenceException  Boolean        @default(false)

  route    Route     @relation(fields: [routeId], references: [id])
  bus      Bus       @relation(fields: [busId], references: [id])
  seats    Seat[]
  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routeId, departureTime])
  @@index([busId, departureTime])
  @@index([recurrenceGroupId])
}

// ─── Seats ───────────────────────────────────────────────────────────────────

model Seat {
  id         Int        @id @default(autoincrement())
  scheduleId Int
  seatNumber String
  row        Int?
  col        Int?
  deck       String?
  status     SeatStatus @default(AVAILABLE)
  heldUntil  DateTime?

  schedule     Schedule      @relation(fields: [scheduleId], references: [id])
  bookingSeats BookingSeat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scheduleId, seatNumber])
  @@index([scheduleId, status])
  @@index([status, heldUntil])
}

// ─── Booking ─────────────────────────────────────────────────────────────────

model Booking {
  id         Int @id @default(autoincrement())
  userId     Int
  scheduleId Int

  baseAmount       Decimal @db.Decimal(10, 2)
  taxAmount        Decimal @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal @default(0) @db.Decimal(10, 2)
  commissionRate   Decimal @default(0.0500) @db.Decimal(5, 4)
  commissionAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal @db.Decimal(10, 2)

  boardingPoint String?
  droppingPoint String?

  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  bookedAt      DateTime      @default(now())
  holdExpiresAt        DateTime?
  expiredAt            DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?

  user     User     @relation(fields: [userId], references: [id])
  schedule Schedule @relation(fields: [scheduleId], references: [id])

  seats             BookingSeat[]
  payment           Payment?
  loyaltyEvents     LoyaltyEvent[]
  couponRedemptions CouponRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, bookedAt])
  @@index([scheduleId, status])
  @@index([status, holdExpiresAt])
}

model BookingSeat {
  id        Int @id @default(autoincrement())
  bookingId Int
  seatId    Int

  booking Booking @relation(fields: [bookingId], references: [id])
  seat    Seat    @relation(fields: [seatId], references: [id])

  createdAt DateTime @default(now())

  @@unique([bookingId, seatId])
}

// ─── Payment ─────────────────────────────────────────────────────────────────

model Payment {
  id          Int           @id @default(autoincrement())
  bookingId   Int           @unique
  provider    String
  providerRef String?
  amount      Decimal       @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  rawResponse String?
  paidAt      DateTime?
  refundedAt  DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// ─── Coupons ─────────────────────────────────────────────────────────────────

model Coupon {
  id             Int        @id @default(autoincrement())
  code           String     @unique
  type           CouponType
  value          Decimal    @db.Decimal(10, 2)
  maxUsesPerUser Int?
  maxGlobalUses  Int?
  usedCount      Int        @default(0)
  isActive       Boolean    @default(true)
  validFrom      DateTime?
  validTo        DateTime?

  redemptions CouponRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CouponRedemption {
  id        Int @id @default(autoincrement())
  couponId  Int
  userId    Int
  bookingId Int

  coupon  Coupon  @relation(fields: [couponId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([couponId, userId])
}

// ─── Loyalty ─────────────────────────────────────────────────────────────────

model LoyaltyEvent {
  id          Int              @id @default(autoincrement())
  userId      Int
  type        LoyaltyEventType
  bookingId   Int?
  credits     Int
  description String?

  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([bookingId])
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  actorId    Int?
  actorRole  String?
  action     String
  entityType String
  entityId   Int?
  metadata   Json?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}
